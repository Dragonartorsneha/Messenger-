<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your chat</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="page-header">
    <h3>Edit your chat: <%= chat._id %></h3>
    </div>
    <div class="edit-card">
    <p> This chat was sent from <b> <%= chat.form %></b> to <b><%= chat.to %></b></p>
    <form method="POST" action="/chats/<%= chat._id%>?_method=PUT">
        <textarea name ="msg" rows="6" cols="50"><%= chat.msg %></textarea>
        <br />
        <button class="btn-save">Edit</button>
    </form>
    </div>
</body>
</html>